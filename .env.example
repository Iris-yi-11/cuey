# GEMINI_API_KEY: Required for server-side Gemini API calls. Use a real key only in .env.local or deployment secrets.
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# GEMINI_MODEL: Optional comma-separated real Gemini model candidates for Work Cue generation.
GEMINI_MODEL="gemini-2.5-flash,gemini-3.1-flash-lite,gemini-3.5-flash,gemini-2.5-flash-lite"

# KV_REST_API_URL: Optional compatibility cache. Supabase daily_cue_snapshots is the recommended preview store.
KV_REST_API_URL="https://replace-with-your-kv-rest-url"

# KV_REST_API_TOKEN: Optional. Store only in .env.local or deployment secrets.
KV_REST_API_TOKEN="replace-with-your-kv-rest-token"

# SUPABASE_URL: Required for preview shipping. Enables Source Management, Daily Cue snapshots, and Cue Bank storage.
SUPABASE_URL="https://replace-with-your-project.supabase.co"

# SUPABASE_SERVICE_ROLE_KEY: Required for preview shipping. Server-side only; never expose in frontend code.
SUPABASE_SERVICE_ROLE_KEY="replace-with-your-supabase-service-role-key"

# VITE_SUPABASE_URL: Required for browser Supabase Auth. Public project URL, safe for frontend.
VITE_SUPABASE_URL="https://replace-with-your-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Required for browser Supabase Auth. Use the public anon key, not service role.
VITE_SUPABASE_ANON_KEY="replace-with-your-supabase-anon-key"

# VITE_PUBLIC_SITE_URL: Optional canonical app URL for local Supabase Auth redirect testing.
VITE_PUBLIC_SITE_URL="https://replace-with-your-public-demo-url"
